{
  "name": "example-basic",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite start",
    "preview": "vite preview",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write --unsafe .",
    "git:commit": "cz",
    "prepare": "husky"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "2.0.0-alpha.2",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/solid-query": "^5.96.2",
    "axios": "^1.13.6",
    "axios-auth-refresh": "^5.0.2",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.20",
    "js-cookie": "^3.0.5",
    "lucide-solid": "^0.577.0",
    "solid-highlight-words": "^1.0.4",
    "solid-js": "^1.9.5",
    "solid-markdown": "^2.1.1",
    "solid-toast": "^0.5.0",
    "solid-zustand": "^2.0.0",
    "tailwindcss": "^4.2.1",
    "vite": "^7.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@tanstack/solid-query-devtools": "^5.96.2",
    "@types/js-cookie": "^3.0.6",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "biome check --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}